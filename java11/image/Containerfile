ARG BASE_IMAGE=quay.io/marolive/custom-udi:1.2.7
FROM ${BASE_IMAGE}

USER 0

ARG MAVEN_VERSION_ARG=3.6.3
ARG GRADLE_VERSION_ARG=7.6.6
ARG SPRING_BOOT_VERSION_ARG=2.7.18

# ---- JDK ----
RUN set -euo pipefail; \
    PM="microdnf"; command -v microdnf >/dev/null 2>&1 || PM="dnf"; \
    $PM install -y java-11-openjdk-devel; \
    $PM clean all;

# ---- Maven + Gradle + Spring Boot CLI ----
RUN set -euo pipefail; \
    curl -fsSL -o /tmp/maven.tgz \
      "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION_ARG}/binaries/apache-maven-${MAVEN_VERSION_ARG}-bin.tar.gz"; \
    mkdir -p /opt/maven; \
    tar -C /opt/maven -xzf /tmp/maven.tgz; \
    ln -s "/opt/maven/apache-maven-${MAVEN_VERSION_ARG}" /opt/maven/current; \
    ln -sf /opt/maven/current/bin/mvn /usr/local/bin/mvn; \
    rm -f /tmp/maven.tgz; \
    chown -R 10001:0 /opt/maven; \
    \
    curl -fsSL -o /tmp/gradle.zip \
      "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION_ARG}-bin.zip"; \
    mkdir -p /opt/gradle; \
    unzip -q /tmp/gradle.zip -d /opt/gradle; \
    ln -s "/opt/gradle/gradle-${GRADLE_VERSION_ARG}" /opt/gradle/current; \
    ln -sf /opt/gradle/current/bin/gradle /usr/local/bin/gradle; \
    rm -f /tmp/gradle.zip; \
    chown -R 10001:0 /opt/gradle; \
    \
    curl -fsSL -o /tmp/sbcli.tgz \
      "https://repo.maven.apache.org/maven2/org/springframework/boot/spring-boot-cli/${SPRING_BOOT_VERSION_ARG}/spring-boot-cli-${SPRING_BOOT_VERSION_ARG}-bin.tar.gz"; \
    mkdir -p /opt/spring-boot-cli; \
    tar -C /opt/spring-boot-cli -xzf /tmp/sbcli.tgz; \
    ln -sf "/opt/spring-boot-cli/spring-${SPRING_BOOT_VERSION_ARG}/bin/spring" /usr/local/bin/spring; \
    rm -f /tmp/sbcli.tgz; \
    chown -R 10001:0 /opt/spring-boot-cli

# ---- Environment config ----
RUN set -euo pipefail; \
    printf 'export JAVA_HOME="/usr/lib/jvm/java-11-openjdk";\nexport PATH="$JAVA_HOME/bin:$PATH";\n' \
      > /etc/profile.d/00-java-tools.sh; \
    printf 'export MAVEN_HOME="/opt/maven/current";\nexport PATH="$MAVEN_HOME/bin:$PATH";\n' \
      > /etc/profile.d/10-maven.sh; \
    printf 'export GRADLE_HOME="/opt/gradle/current";\nexport PATH="$GRADLE_HOME/bin:$PATH";\n' \
      > /etc/profile.d/11-gradle.sh; \
    chmod 0644 /etc/profile.d/00-java-tools.sh /etc/profile.d/10-maven.sh /etc/profile.d/11-gradle.sh; \
    \
    printf '%s\n' \
      '<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"' \
      '        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"' \
      '        xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">' \
      '  <mirrors>' \
      '    <mirror>' \
      '      <id>nexus</id>' \
      '      <mirrorOf>*</mirrorOf>' \
      '      <url>NEXUS_MAVEN_BASEURL_PLACEHOLDER</url>' \
      '    </mirror>' \
      '  </mirrors>' \
      '  <servers>' \
      '    <server>' \
      '      <id>nexus</id>' \
      '      <username>SEU_USUARIO</username>' \
      '      <password>SUA_SENHA</password>' \
      '    </server>' \
      '  </servers>' \
      '</settings>' > ~/.m2/settings.xml; \
    chmod 666 ~/.m2/settings.xml

ENV JAVA_HOME="/usr/lib/jvm/java-11-openjdk" \
    MAVEN_HOME="/opt/maven/current" \
    GRADLE_HOME="/opt/gradle/current" \
    PATH="/usr/lib/jvm/java-11-openjdk/bin:/opt/maven/current/bin:/opt/gradle/current/bin:${PATH}"

USER 10001
CMD ["bash", "-lc", "sleep infinity"]
